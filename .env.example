# ===== CashUp API =====
CASHUP_BASE_URL=http://localhost:3000
CASHUP_CLIENT_ID=cli_abc123
CASHUP_CLIENT_SECRET=sec_super_secreta

# ===== Database =====
# Tipo: oracle, firebird, sqlserver
DB_TYPE=oracle
DB_HOST=localhost
DB_PORT=1521
DB_USER=seu_usuario
DB_PASS=sua_senha
DB_NAME=seu_banco
# Para Oracle: pode ser SID ou Service Name
DB_SERVICE_NAME=
DB_SID=

# ===== Sync =====
SYNC_BATCH_SIZE=50
# Intervalo global padrão (minutos). Usado como fallback por entidades sem
# camada/override definido.
SYNC_INTERVAL_MINUTES=30
# Intervalo por entidade (opcional). Sobrescreve a camada padrão do código.
# Formato: SYNC_INTERVAL_<ENTIDADE>=<minutos>. Ex.:
#   SYNC_INTERVAL_ESTOQUE=5
#   SYNC_INTERVAL_NOTAS_FISCAIS=15
#   SYNC_INTERVAL_CLIENTES=60
# Carga total por entidade (opcional): quando 'true', a entidade sempre
# sincroniza tudo a cada ciclo, ignorando o ID_SINC (watermark). Útil quando
# controlar registros alterados é inviável. Por padrão nenhuma entidade é
# full-sync — defina aqui as que precisarem.
# Formato: SYNC_FULL_<ENTIDADE>=true|false. Ex.:
#   SYNC_FULL_ESTOQUE=true

# ===== Application =====
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
